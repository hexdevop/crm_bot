clients-menu =
    <b>👥 Клиенты</b>

    Выберите клиента или добавьте нового

clients-empty = Клиентов пока нет. Нажмите кнопку ниже, чтобы добавить.

client-view =
    <b>👤 Клиент</b>

    📛 Имя: <b>{ $name }</b>
    🆔 Telegram ID: <code>{ $telegram_id }</code>
    📌 Username: { $username }

    🖥 Серверов: <b>{ $servers_count }</b>

client-notes =
    <b>📝 Заметки — { $name }</b>

    { $notes }

notes-empty = <i>Заметок пока нет</i>

client-add-telegram-id =
    Введите <b>Telegram ID</b> клиента:
    (например: <code>123456789</code>)

client-add-name = Введите <b>имя</b> клиента:

client-add-username =
    Введите <b>@username</b> клиента (без @):
    Или нажмите «Пропустить»

client-edit-name = Введите <b>новое имя</b> клиента:

client-edit-username =
    Введите <b>новый @username</b> клиента (без @):
    Нажмите «Пропустить» чтобы очистить

client-edit-notes =
    Введите <b>заметки</b> по клиенту:
    (Нажмите «Пропустить» чтобы очистить)

client-added =
    ✅ Клиент <b>{ $name }</b> добавлен!

client-already-exists = ⚠️ Клиент с таким Telegram ID уже существует

client-not-found = ❌ Клиент не найден

client-deleted = ✅ Клиент удалён

client-delete-confirm =
    ❓ Удалить клиента <b>{ $name }</b>?

    ⚠️ Это также удалит все его серверы и ботов!

field-updated = ✅ Обновлено
